# GSC + GA4 API 接入 — OAuth 2.0 凭据

# OAuth 2.0 客户端凭据（Google Cloud Console → 桌面应用）
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# GSC 站点 URL（sc-domain 格式用于域名级属性，或完整 URL 用于 URL 前缀属性）
GSC_SITE_URL=sc-domain:ctofconverter.com

# GA4 媒体资源 ID
GA4_PROPERTY_ID=123456789

# ── 设置步骤 ────────────────────────────────────────────────
# 1. 复制此文件为 .env.local，填入真实凭据
# 2. 运行：node scripts/auth-oauth.mjs（一次性浏览器授权）
# 3. node scripts/fetch-analytics.mjs > data.json
